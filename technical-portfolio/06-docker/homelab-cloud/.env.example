# ============================================================
# homelab-cloud Environment Variables
# How to use: cp .env.example .env, then fill in your values
# ⚠️ Never commit your real .env file to Git!
# ============================================================

# Nextcloud
NEXTCLOUD_ADMIN_USER=admin
NEXTCLOUD_ADMIN_PASSWORD=change_this_to_your_own_password
NEXTCLOUD_DB_PASSWORD=change_this_to_your_own_password
NEXTCLOUD_DB_ROOT_PASSWORD=change_this_to_your_own_password

# Immich
IMMICH_DB_PASSWORD=change_this_to_your_own_password

# Vaultwarden
VAULTWARDEN_ADMIN_TOKEN=change_this_to_a_random_long_string
